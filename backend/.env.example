# ══════════════════════════════════════════════════════════════
# stuRENT — Environment Variables Template
# Copy this file to .env and fill in your actual values
# ⚠️  NEVER commit the real .env file — only this template!
# ══════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database (default: SQLite for development) ───────────────
# Uncomment below for PostgreSQL in production:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=sturent
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# ── JWT ───────────────────────────────────────────────────────
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
